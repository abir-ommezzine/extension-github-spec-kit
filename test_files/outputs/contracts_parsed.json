            "type": "entity",
            "identifier": "ENT-ENROLLMENT",
            "content": "Enrollment entity linking a student to a course with progress tracking.",
            "source_section": "Enrollment",
            "attributes": {}
        },
        {
            "type": "functional_requirement",
            "identifier": "REQ-AUTH-REG",
            "content": "Allow students to self-register with email, password, and display name, triggering an async welcome email.",
            "source_section": "POST `/api/v1/auth/register`",
            "attributes": {
                "role": "Student"
            }
        },
        {
            "type": "functional_requirement",
            "identifier": "REQ-COURSE-CREATE",
            "content": "Allow instructors to create courses with associated modules.",
            "source_section": "POST `/api/v1/courses`",
            "attributes": {
                "role": "Instructor"
            }
        },
        {
            "type": "constraint",
            "identifier": "RULE-ACTIVE-ENROLL",
            "content": "ActiveEnrollmentConstraint: A course cannot be deleted if it has active enrollments (409 Conflict).",
            "source_section": "DELETE `/api/v1/courses/{course_id}`",
            "attributes": {
                "error_code": "ACTIVE_ENROLLMENT_CONSTRAINT"
            }
        },
        {
            "type": "functional_requirement",
            "identifier": "REQ-ENROLL-STUDENT",
            "content": "Allow students to enroll in published courses, ensuring no duplicate enrollments.",
            "source_section": "POST `/api/v1/enrollments`",
            "attributes": {
                "role": "Student"
            }
        },
        {
            "type": "functional_requirement",
            "identifier": "REQ-ENROLL-AUTOCOMPLETE",
            "content": "Automatically set completed_at timestamp when progress reaches 100%.",
            "source_section": "PUT `/api/v1/enrollments/{enrollment_id}`",
            "attributes": {
                "trigger": "progress == 100"
            }
        }
